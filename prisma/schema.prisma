//////////////////////////////////////////////////////
// TOOLS
//////////////////////////////////////////////////////

model MCPTool {
  id String @id @default(uuid())

  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  name String
  type ToolType

  config Json?

  isActive Boolean @default(true)

  fields MCPToolField[]

  logs     MCPToolLog[]
  webhooks Webhook[]

  @@index([dashboardId])
}

model MCPToolField {
  id String @id @default(uuid())

  toolId String
  tool   MCPTool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  name String
  type FieldType
  kind FieldKind

  isRequired Boolean @default(false)

  @@unique([toolId, name, kind])
}

model MCPToolLog {
  id String @id @default(uuid())

  toolId String
  tool   MCPTool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  input  Json
  output Json?

  success Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// WEBHOOK
//////////////////////////////////////////////////////

model Webhook {
  id String @id @default(uuid())

  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  toolId String?
  tool   MCPTool? @relation(fields: [toolId], references: [id])

  endpoint String?
  method   HttpMethod
  status   WebhookStatus

  secret String?

  logs WebhookLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dashboardId, endpoint])
}

model WebhookLog {
  id String @id @default(uuid())

  webhookId String
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  success   Boolean
  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// DATA STORE
//////////////////////////////////////////////////////

model DataStore {
  id String @id @default(uuid())

  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  name String

  records DataStoreRecord[]

  @@unique([dashboardId, name])
}

model DataStoreRecord {
  id String @id @default(uuid())

  dataStoreId String
  dataStore   DataStore @relation(fields: [dataStoreId], references: [id], onDelete: Cascade)

  key   String
  value Json?

  @@unique([dataStoreId, key])
}

//////////////////////////////////////////////////////
// CREDENTIAL SYSTEM
//////////////////////////////////////////////////////

model Credential {
  id String @id @default(uuid())

  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  name String
  type CredentialType

  connections Connection[]
  apiKeys     CredentialKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dashboardId])
}

model Connection {
  id String @id @default(uuid())

  credentialId String
  credential   Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  provider     String
  accessToken  String  @db.Text
  refreshToken String? @db.Text

  expiresAt DateTime?

  createdAt DateTime @default(now())
}

model CredentialKey {
  id String @id @default(uuid())

  credentialId String
  credential   Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  keyName  String
  keyValue String @db.Text

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// DEVICE LOGIN SYSTEM
//////////////////////////////////////////////////////

model Device {
  id String @id @default(uuid())

  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  name String
  type DeviceType

  isActive Boolean @default(false)

  tokens DeviceAccessToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dashboardId])
}

model DeviceAccessToken {
  id String @id @default(uuid())

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// CUSTOM APPS
//////////////////////////////////////////////////////

model CustomApp {
  id String @id @default(uuid())

  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  appLogo String?
  appName        String
  module Int @default(0)
  theme String @default("#000")
  label String?
  description String?
  language String? @default("English")
  audience String? @default("Global")
  country String?
  mode AppMode @default(EDITABLE)
  type AppType @default(CUSTOM)

  @@unique([dashboardId, appName])
}

//////////////////////////////////////////////////////
// VARIABLES
//////////////////////////////////////////////////////

model Variable {
  id String @id @default(uuid())

  orgId String
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type VariableType?
  name  String
  value String
  dataType String?
  variableFor String?
  variableName VariableName?

  @@unique([orgId, name])
}
