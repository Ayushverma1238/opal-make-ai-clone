generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  SUCCESS
  FAILED
  PENDING
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

enum ScenarioStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ScenarioVisibility {
  PRIVATE
  TEAM
  PUBLIC
}

enum CredentialType {
  CONNECTION
  API_KEY
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HttpMethod {
  GET
  POST
  PUT
  DELETE
}

enum WebhookStatus {
  ACTIVE
  INACTIVE
}

enum ToolType {
  SCENARIO
  MODULE
}

enum FieldKind {
  INPUT
  OUTPUT
}

enum FieldType {
  ARRAY
  COLLECTION
  DATE
  TEXT
  NUMBER
  BOOLEAN
  BINARY_DATA
}

enum ScenarioType {
  ALL
  UNCATEGORIZE
  MODULETOOLS
}

enum DeviceType {
  GOOGLE
  GMAIL
  PLAY_STORE
  APPLE
  OTHER
}

enum AppMode {
  READ_ONLY
  EDITABLE
  ADMIN_ONLY
}

enum AppType {
  EXAMPLE
  CUSTOM
}

enum VariableType {
  ALL
  CUSTOM
  SYSTEM
}

enum VariableName {
  TEAM
  ORGANIZATION
}

enum TemplateType {
  PUBLIC
  TEAM
}

//////////////////////////////////////////////////////
// USER & AUTH
//////////////////////////////////////////////////////

model User {
  id       String  @id @default(uuid())
  name     String?
  email    String  @unique
  password String?
  image    String?
  lastLoginAt DateTime?
  role       UserRole @default(USER)
  scenarios Scenario[]
  emailVerified DateTime?
  
  dashboards    Dashboard[]
  subscriptions Subscription[]
  payments      Payment[]
  accounts Account[]
  sessions Session[]
  teams Team[] @relation("TeamOwner")

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  dashboardUsers DashboardUser[]
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String

  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String @id @default(uuid())
  sessionToken String @unique
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expires DateTime
}

//////////////////////////////////////////////////////
// DASHBOARD
//////////////////////////////////////////////////////

model Dashboard {
  id   String @id @default(uuid())
  name String

  userId String 
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orgs        Org[]
  scenarios   Scenario[]
  tools       MCPTool[]
  credentials Credential[]
  webhooks    Webhook[]
  dataStores  DataStore[]
  devices     Device[]
  apps        CustomApp[]
  folders  Folder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

//////////////////////////////////////////////////////
// ORGANIZATION
//////////////////////////////////////////////////////

model Org {
  id          String    @id @default(uuid())
  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  timeZone String? @default("(GMT+05:30) Asia/Kolkata")
  name String
  hostedRegion String? @default("EU")
  country String? @default("India")
  partnerLink String?
  teams     Team[]
  variables Variable[]
  usage     UsageStats?

  createdAt DateTime @default(now())

  @@index([dashboardId])
}

model UsageStats {
  id    String @id @default(uuid())
  orgId String @unique
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  creditsLeft       Int @default(1000)
  averageDailyUsage Int @default(0)
  daysLeft  Int @default(30)
  activeScenarios   Int @default(0)
}

//////////////////////////////////////////////////////
// TEAM & MEMBERS
//////////////////////////////////////////////////////

model Team {
  id      String @id @default(uuid())
  name    String

  orgId   String
org     Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownerId String
owner   User @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members DashboardUser[]
}

model DashboardUser {
  id String @id @default(uuid())

  name  String?
  email String
  role  UserRole
  note String?

  teamId String
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([email, teamId])
  @@unique([userId, teamId])
  @@index([teamId])
}

//////////////////////////////////////////////////////
// SUBSCRIPTION & PAYMENT
//////////////////////////////////////////////////////

model Plan {
  id   String   @id @default(uuid())

  name  PlanType
  title String

  price        Float
  credits      Int
  billing      BillingCycle

  maxScenarios Int
  maxTeams     Int

  subscriptions Subscription[]

  @@unique([title, billing])
}

model Subscription {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  status SubscriptionStatus @default(ACTIVE)

  startDate DateTime  @default(now())
  endDate   DateTime? 

  updatedAt DateTime @updatedAt

  payments Payment[]

  @@index([planId])
  @@index([userId, status])
}

model Payment {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  amount   Int
  currency String @default("DOLLER")
  product String?
  paymentMethod String?
  BillingPeriod String?
  
  status PaymentStatus
  method String

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// SCENARIO ENGINE
//////////////////////////////////////////////////////

model Scenario {
  id String @id @default(uuid())

  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  title       String?
  description String?

  status     ScenarioStatus     @default(INACTIVE)
  visibility ScenarioVisibility @default(PUBLIC)
  scenarioType ScenarioType?   @default(UNCATEGORIZE)

  credits Int @default(0)
  dataTransfer Int @default(0)

  createdBy String?
  user User? @relation(fields:[createdBy], references:[id], onDelete: Cascade)
  version Int @default(1)

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: Cascade)

  executions ScenarioExecution[]

  folderId String?
  folder Folder? @relation(fields:[folderId], references:[id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dashboardId, title])
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model ScenarioExecution {
  id String @id @default(uuid())

  scenarioId String
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  status     ExecutionStatus
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  logs Json?
 
  @@index([scenarioId])
}

model Template {
  id String @id @default(uuid())

  scenarios Scenario[]
  templateType TemplateType @default(PUBLIC)
  title String
  description String?
  imageUrl String?
  usedCount Int @default(0)
  templateApps String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Folder {
  id String @id @default(uuid())
  name String
  scenarios Scenario[]
  dashboardId String
  dashboard Dashboard @relation(fields:[dashboardId], references:[id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model App {
  id String @id @default(uuid())

  name String?
  imageUrl String?
  theme String?

}

